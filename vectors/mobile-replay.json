{
  "description": "Synthetic rrweb stream for mobile visual replay (SPEC-mobile.md §6.5, format_version 1). Each case feeds the synthesizer a capture timeline and pins the exact rrweb events it must produce, byte-for-byte under deep equality. Node ids are pinned (document 1, html 2, head 3, body 4, img 5); numeric constants are rrweb's published enums (EventType Meta=4 Custom=5 FullSnapshot=2 IncrementalSnapshot=3; IncrementalSource Mutation=0 MouseInteraction=2 ViewportResize=4; MouseInteractions Click=2).",
  "imgStyle": "width:100vw;height:100vh;object-fit:contain;background:#000",
  "cases": [
    {
      "name": "recording_start_single_frame",
      "input": {
        "platform": "ios",
        "sdkVersion": "0.3.0",
        "width": 390,
        "height": 844,
        "initialScreen": "home",
        "events": [
          { "kind": "frame", "at": 1720000000000, "dataUri": "data:image/jpeg;base64,FRAME0" }
        ]
      },
      "expected": [
        { "type": 4, "data": { "href": "kilden-app://screen/home", "width": 390, "height": 844 }, "timestamp": 1720000000000 },
        { "type": 5, "data": { "tag": "kilden_mobile_meta", "payload": { "format_version": 1, "platform": "ios", "sdk_version": "0.3.0" } }, "timestamp": 1720000000000 },
        { "type": 2, "data": { "node": { "type": 0, "childNodes": [ { "type": 2, "tagName": "html", "attributes": {}, "childNodes": [ { "type": 2, "tagName": "head", "attributes": {}, "childNodes": [], "id": 3 }, { "type": 2, "tagName": "body", "attributes": {}, "childNodes": [ { "type": 2, "tagName": "img", "attributes": { "src": "data:image/jpeg;base64,FRAME0", "style": "width:100vw;height:100vh;object-fit:contain;background:#000" }, "childNodes": [], "id": 5 } ], "id": 4 } ], "id": 2 } ], "id": 1 }, "initialOffset": { "left": 0, "top": 0 } }, "timestamp": 1720000000000 }
      ]
    },
